# ─── Segurança ───────────────────────────────────────────
# Chave usada para assinar cookies de sessão (gere algo longo e aleatório)
SESSION_SECRET=troque-isto-por-uma-string-aleatoria-bem-longa

# Chave Fernet usada para criptografar a senha SMTP no banco
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=troque-isto-por-uma-chave-fernet-valida

# ─── Diretório de dados (SQLite + currículos) ────────────
# No EasyPanel, monte o volume aqui
DATA_DIR=/data

# ─── Usuário inicial (criado no primeiro start) ──────────
ADMIN_EMAIL=victor@exemplo.com
ADMIN_NOME=Victor Maziero
ADMIN_SENHA=trocar-na-primeira-execucao

# Segundo usuário opcional (esposa)
USER2_EMAIL=
USER2_NOME=
USER2_SENHA=
